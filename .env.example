# ============================================
# Variáveis de Ambiente — Império Ecolog Logística
# ============================================
# Copie este arquivo como .env e preencha os valores.

# === GEMINI AI (Obrigatório para OCR) ===
# Chave de API do Google Gemini para processamento OCR
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# === FIREBASE (Autenticação e Storage) ===
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_APP_ID="your-app-id"
FIREBASE_API_KEY="your-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# === APP ===
# URL onde o app está hospedado (preenchido automaticamente no Netlify)
APP_URL="http://localhost:3000"

# === BANCO DE DADOS (Backend NestJS — não usado no Netlify) ===
# DATABASE_URL="postgresql://root:rootpassword@localhost:5432/imperio_ecolog"

# === NETLIFY (CI/CD) ===
# NETLIFY_AUTH_TOKEN="your-netlify-auth-token"
# NETLIFY_SITE_ID="your-netlify-site-id"
